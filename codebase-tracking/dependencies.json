{
  "metadata": {
    "lastUpdated": "2025-05-30",
    "version": "1.0.0",
    "description": "Complete dependency mapping for Security Access Management System"
  },
  "externalLibraries": {
    "chartjs": {
      "name": "Chart.js",
      "source": "https://cdn.jsdelivr.net/npm/chart.js",
      "version": "Latest",
      "purpose": "Dashboard charts and data visualization",
      "usedBy": ["DashboardManager"],
      "features": ["Line charts", "Pie charts", "Real-time updates", "Responsive design"],
      "fallback": "Disable charts if library fails to load"
    },
    "qrcode": {
      "name": "QRCode.js",
      "source": "https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js",
      "version": "1.5.3",
      "purpose": "QR code generation for personnel",
      "usedBy": ["QRGenerator"],
      "features": ["QR code generation", "Base64 output", "Error correction"],
      "fallback": "Disable QR features if library fails to load"
    },
    "materialIcons": {
      "name": "Material Design Icons",
      "source": "https://fonts.googleapis.com/icon?family=Material+Icons",
      "version": "Latest",
      "purpose": "UI icons throughout the application",
      "usedBy": ["All components"],
      "features": ["Consistent iconography", "Vector icons", "Accessibility"],
      "fallback": "Text labels if icons fail to load"
    },
    "robotoFont": {
      "name": "Roboto Font",
      "source": "https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap",
      "version": "Latest",
      "purpose": "Primary typography",
      "usedBy": ["All components"],
      "features": ["Multiple weights", "Readable typography", "Web optimized"],
      "fallback": "System fonts if web font fails to load"
    }
  },
  "internalDependencies": {
    "SecurityApp": {
      "dependsOn": [
        "StorageManager",
        "DashboardManager",
        "CameraManager", 
        "EmergencyManager",
        "OCRManager",
        "QRGenerator",
        "ReportsManager",
        "ShiftManager",
        "TutorialManager",
        "ExportManager"
      ],
      "provides": [
        "Application lifecycle",
        "Event coordination",
        "UI state management",
        "Page navigation"
      ]
    },
    "StorageManager": {
      "dependsOn": [],
      "dependedOnBy": [
        "SecurityApp",
        "DashboardManager",
        "EmergencyManager",
        "ReportsManager",
        "ShiftManager"
      ],
      "provides": [
        "Data persistence",
        "Personnel management",
        "Activity logging",
        "Statistics calculation"
      ]
    },
    "DashboardManager": {
      "dependsOn": [
        "StorageManager",
        "Chart.js"
      ],
      "dependedOnBy": ["SecurityApp"],
      "provides": [
        "Data visualization",
        "Real-time updates",
        "Chart management"
      ]
    },
    "CameraManager": {
      "dependsOn": [],
      "dependedOnBy": [
        "SecurityApp",
        "OCRManager"
      ],
      "provides": [
        "Camera access",
        "Photo capture",
        "Image processing"
      ]
    },
    "EmergencyManager": {
      "dependsOn": ["StorageManager"],
      "dependedOnBy": ["SecurityApp"],
      "provides": [
        "Emergency procedures",
        "Evacuation management",
        "Emergency reporting"
      ]
    },
    "OCRManager": {
      "dependsOn": ["CameraManager"],
      "dependedOnBy": ["SecurityApp"],
      "provides": [
        "Text recognition",
        "ID card scanning",
        "Automated data entry"
      ]
    },
    "QRGenerator": {
      "dependsOn": ["QRCode.js"],
      "dependedOnBy": ["SecurityApp"],
      "provides": [
        "QR code generation",
        "Personnel QR codes",
        "Bulk QR operations"
      ]
    },
    "ReportsManager": {
      "dependsOn": ["StorageManager"],
      "dependedOnBy": ["SecurityApp"],
      "provides": [
        "Advanced reporting",
        "Analytics",
        "Data insights"
      ]
    },
    "ShiftManager": {
      "dependsOn": ["StorageManager"],
      "dependedOnBy": ["SecurityApp"],
      "provides": [
        "Shift operations",
        "Handover management",
        "Officer scheduling"
      ]
    },
    "ExportManager": {
      "dependsOn": [],
      "dependedOnBy": [
        "SecurityApp",
        "ReportsManager"
      ],
      "provides": [
        "Data export",
        "Multiple formats",
        "Report generation"
      ]
    },
    "TutorialManager": {
      "dependsOn": [],
      "dependedOnBy": ["SecurityApp"],
      "provides": [
        "User onboarding",
        "Interactive tutorials",
        "Help system"
      ]
    }
  },
  "syncComponentDependencies": {
    "SyncClient": {
      "dependsOn": ["WebSocket API"],
      "provides": ["Real-time synchronization", "Multi-device communication"],
      "optional": true,
      "fallback": "Local-only operation"
    },
    "P2PSync": {
      "dependsOn": ["HTTP Fetch API", "Local network access"],
      "provides": ["Peer-to-peer sync", "Coordinator-client architecture"],
      "optional": true,
      "fallback": "Local-only operation"
    },
    "MeshSync": {
      "dependsOn": ["Local network access"],
      "provides": ["Simplified mesh networking", "Device discovery"],
      "optional": true,
      "fallback": "Local-only operation"
    }
  },
  "browserAPIs": {
    "localStorage": {
      "purpose": "Data persistence",
      "required": true,
      "fallback": "In-memory storage with data loss warning",
      "usedBy": ["StorageManager"]
    },
    "mediaDevices": {
      "purpose": "Camera access for photos and scanning",
      "required": false,
      "fallback": "File upload for photos",
      "usedBy": ["CameraManager", "OCRManager"]
    },
    "permissions": {
      "purpose": "Camera permission checking",
      "required": false,
      "fallback": "Direct camera access attempt",
      "usedBy": ["CameraManager"]
    },
    "navigator": {
      "purpose": "Device capabilities and online status",
      "required": false,
      "fallback": "Assume capabilities available",
      "usedBy": ["SecurityApp", "CameraManager"]
    },
    "fetch": {
      "purpose": "Network requests for sync operations",
      "required": false,
      "fallback": "Disable sync features",
      "usedBy": ["P2PSync", "SyncClient"]
    },
    "webSocket": {
      "purpose": "Real-time communication",
      "required": false,
      "fallback": "Polling or local-only operation",
      "usedBy": ["SyncClient"]
    }
  },
  "fileStructureDependencies": {
    "htmlStructure": {
      "index.html": {
        "dependsOn": [
          "css/styles.css",
          "css/themes.css",
          "js/app.js",
          "All component JS files"
        ],
        "provides": "Application shell and DOM structure"
      }
    },
    "cssStructure": {
      "styles.css": {
        "dependsOn": ["CSS custom properties", "Material Design principles"],
        "provides": "Main application styling"
      },
      "themes.css": {
        "dependsOn": ["styles.css"],
        "provides": "Theme variations and color schemes"
      }
    },
    "jsStructure": {
      "loadOrder": [
        "External libraries (Chart.js, QRCode.js)",
        "Component classes",
        "Main application (app.js)"
      ],
      "globalScope": {
        "window.StorageManager": "Global storage access",
        "window.app": "Main application instance",
        "Component instances": "Global component access"
      }
    }
  },
  "developmentDependencies": {
    "none": {
      "description": "No build tools or development dependencies required",
      "deployment": "Static files served directly",
      "benefits": "Simple deployment and maintenance"
    }
  },
  "runtimeRequirements": {
    "browser": {
      "minimum": "Modern browsers supporting ES6+",
      "features": [
        "CSS Grid and Flexbox",
        "ES6 Classes and Arrow Functions",
        "Fetch API",
        "LocalStorage API",
        "Modern JavaScript features"
      ]
    },
    "network": {
      "offline": "Full functionality available offline",
      "online": "Enhanced sync capabilities when online",
      "localNetwork": "P2P sync on local network"
    }
  },
  "securityDependencies": {
    "noExternalAPIs": {
      "description": "No external API keys or services required",
      "security": "All data stays local",
      "privacy": "No data transmission to external servers"
    },
    "httpsRecommended": {
      "description": "HTTPS required for camera access",
      "fallback": "File upload if camera unavailable over HTTP"
    }
  },
  "optionalEnhancements": {
    "serviceWorker": {
      "file": "service-worker.js",
      "purpose": "Offline caching and PWA capabilities", 
      "status": "Disabled for development",
      "implementation": "Can be enabled for production"
    },
    "webManifest": {
      "purpose": "PWA installation and mobile optimization",
      "status": "Not implemented",
      "implementation": "Can be added for app-like experience"
    }
  },
  "scalabilityConsiderations": {
    "dataLimits": {
      "localStorage": "~5-10MB typical browser limit",
      "personnel": "Hundreds to low thousands of records",
      "activities": "Automatic cleanup after retention period"
    },
    "performanceImpact": {
      "charts": "Chart.js handles large datasets efficiently",
      "search": "Linear search acceptable for typical use cases",
      "sync": "Network-dependent performance for sync operations"
    }
  }
}