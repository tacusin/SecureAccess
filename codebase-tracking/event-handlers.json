  "keyboardShortcuts": [
    {
      "key": "Ctrl+D",
      "action": "navigateTo('dashboard')",
      "description": "Navigate to dashboard"
    },
    {
      "key": "Ctrl+C",
      "action": "navigateTo('checkin')",
      "description": "Navigate to check-in page"
    },
    {
      "key": "Ctrl+P",
      "action": "navigateTo('personnel')",
      "description": "Navigate to personnel page"
    },
    {
      "key": "Ctrl+A",
      "action": "navigateTo('activity')",
      "description": "Navigate to activity log"
    },
    {
      "key": "Ctrl+N",
      "action": "showAddPersonnelModal()",
      "description": "Add new personnel"
    },
    {
      "key": "Escape",
      "action": "closeModal()",
      "description": "Close open modal"
    }
  ],
  "customEvents": [
    {
      "eventName": "personnel-added",
      "description": "Fired when new personnel is added",
      "triggeredBy": ["StorageManager.addPersonnel"],
      "listeners": ["updateDashboard", "loadPersonnelList"]
    },
    {
      "eventName": "personnel-status-changed",
      "description": "Fired when personnel check-in/out status changes",
      "triggeredBy": ["StorageManager.checkIn", "StorageManager.checkOut"],
      "listeners": ["updateDashboard", "updateActivityPage"]
    },
    {
      "eventName": "emergency-activated",
      "description": "Fired when emergency mode is activated",
      "triggeredBy": ["EmergencyManager.activateEmergencyMode"],
      "listeners": ["updateUI", "broadcastAlert"]
    },
    {
      "eventName": "shift-started",
      "description": "Fired when new shift starts",
      "triggeredBy": ["ShiftManager.startShift"],
      "listeners": ["updateShiftsPage", "logActivity"]
    },
    {
      "eventName": "shift-ended",
      "description": "Fired when shift ends",
      "triggeredBy": ["ShiftManager.endShift"],
      "listeners": ["updateShiftsPage", "logActivity"]
    },
    {
      "eventName": "handover-created",
      "description": "Fired when handover is created",
      "triggeredBy": ["ShiftManager.createHandover"],
      "listeners": ["updateShiftsPage", "notifyNextShift"]
    },
    {
      "eventName": "data-synced",
      "description": "Fired when data synchronization completes",
      "triggeredBy": ["SyncClient.processSyncEvent", "P2PSync.applySyncData"],
      "listeners": ["updateAllPages", "showSyncStatus"]
    },
    {
      "eventName": "theme-changed",
      "description": "Fired when application theme changes",
      "triggeredBy": ["toggleTheme"],
      "listeners": ["applyTheme", "updateChartThemes"]
    }
  ]
}