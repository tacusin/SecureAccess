{
  "metadata": {
    "lastUpdated": "2025-05-30",
    "version": "1.1.0",
    "description": "High-level system summary and quick reference guide - Updated with sync improvements"
  },
  "projectOverview": {
    "name": "Security Access Management System",
    "type": "Progressive Web Application",
    "architecture": "Client-side modular JavaScript with offline-first design",
    "primaryPurpose": "Enterprise-grade security personnel management with real-time synchronization",
    "keyFeatures": [
      "Personnel check-in/out management",
      "Real-time dashboard analytics",
      "Shift management and handovers",
      "Emergency evacuation procedures",
      "Advanced reporting and analytics",
      "Multi-device synchronization",
      "Offline-first operation",
      "Camera integration for photos and scanning",
      "QR code generation and scanning",
      "QR-based sync host connection",
      "Data export in multiple formats"
    ]
  },
  "coreModules": {
    "app.js": {
      "role": "Main application controller",
      "keyFunctions": ["init", "setupEventListeners", "navigateTo", "updatePageContent", "togglePersonStatus"],
      "responsibilities": "UI coordination, event handling, page navigation"
    },
    "storage.js": {
      "role": "Data persistence layer", 
      "keyFunctions": ["addPersonnel", "checkIn", "checkOut", "logActivity", "saveToStorage"],
      "responsibilities": "Data management, localStorage operations, statistics"
    },
    "dashboard.js": {
      "role": "Analytics and visualization",
      "keyFunctions": ["initializeCharts", "updateRealTimeData", "getOccupancyTrendData"],
      "responsibilities": "Charts, real-time updates, performance metrics"
    },
    "shifts.js": {
      "role": "Shift operations",
      "keyFunctions": ["startShift", "endShift", "createHandover", "acknowledgeHandover"],
      "responsibilities": "Shift lifecycle, handover documentation, officer scheduling"
    },
    "emergency.js": {
      "role": "Emergency procedures",
      "keyFunctions": ["activateEmergencyMode", "generateEvacuationList", "performEmergencyCheckout"],
      "responsibilities": "Emergency protocols, evacuation management, crisis response"
    }
  },
  "dataStructures": {
    "personnel": {
      "primaryKey": "id",
      "criticalFields": ["name", "role", "status"],
      "relationships": "One-to-many with activities"
    },
    "activities": {
      "primaryKey": "id", 
      "criticalFields": ["timestamp", "action", "personId"],
      "relationships": "Many-to-one with personnel"
    },
    "shifts": {
      "primaryKey": "id",
      "criticalFields": ["officer1Name", "startTime", "status"],
      "relationships": "One-to-many with handovers"
    }
  },
  "userInteractionFlows": {
    "basicCheckIn": [
      "Navigate to Check In/Out page",
      "Search for person or click person card", 
      "Click to toggle status",
      "System logs activity and updates dashboard"
    ],
    "addNewVisitor": [
      "Click Add Visitor button",
      "Fill out form with required details",
      "Optionally capture photo",
      "Submit form",
      "Person added to system and ready for check-in"
    ],
    "generateReport": [
      "Navigate to Reports page",
      "Click on desired report type",
      "System generates analysis",
      "View report in modal",
      "Export to PDF/CSV if needed"
    ],
    "emergencyEvacuation": [
      "Click Emergency button",
      "System activates emergency mode",
      "Generate evacuation list",
      "Perform emergency checkout",
      "Export evacuation report"
    ]
  },
  "technicalArchitecture": {
    "frontend": "Vanilla JavaScript ES6+ with modular class structure",
    "styling": "CSS3 with custom properties and responsive design",
    "dataLayer": "Browser localStorage with automatic persistence",
    "synchronization": "Optional P2P and WebSocket sync for multi-device support",
    "external": "Chart.js for visualizations, QRCode.js for QR generation"
  },
  "deploymentRequirements": {
    "server": "Static file server (Python http.server, nginx, Apache, etc.)",
    "browser": "Modern browser with ES6+ support",
    "storage": "5-10MB localStorage capacity",
    "network": "Optional for sync features, fully functional offline",
    "permissions": "Camera access for photo capture (optional)"
  },
