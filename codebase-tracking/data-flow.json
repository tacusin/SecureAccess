{
  "metadata": {
    "lastUpdated": "2025-05-30",
    "version": "1.0.0",
    "description": "Data flow patterns and storage operations for Security Access Management System"
  },
  "storageOperations": {
    "localStorage": {
      "keys": {
        "security_access_data": {
          "description": "Main application data container",
          "structure": {
            "lastSaved": "ISO timestamp",
            "version": "Application version"
          },
          "managedBy": "StorageManager"
        },
        "personnel_data": {
          "description": "Personnel records array",
          "structure": {
            "id": "Unique identifier",
            "name": "Full name",
            "role": "employee|contractor|visitor|vip",
            "company": "Company name",
            "phone": "Phone number",
            "email": "Email address",
            "photo": "Base64 image data",
            "status": "checked-in|checked-out",
            "checkedInAt": "Timestamp",
            "checkedOutAt": "Timestamp",
            "totalVisits": "Visit count",
            "lastActivity": "Last activity timestamp",
            "emergencyContact": "Emergency contact info",
            "notes": "Additional notes"
          },
          "managedBy": "StorageManager"
        },
        "activity_log": {
          "description": "Activity log entries array",
          "structure": {
            "id": "Unique identifier",
            "timestamp": "ISO timestamp",
            "action": "check_in|check_out|personnel_added|personnel_updated|emergency_activated|shift_started|shift_ended",
            "personId": "Related person ID",
            "data": {
              "duration": "Visit duration in ms",
              "reason": "Action reason",
              "officer": "Officer name",
              "additional": "Extra data"
            }
          },
          "managedBy": "StorageManager"
        },
        "app_settings": {
          "description": "Application settings",
          "structure": {
            "autoSave": "boolean",
            "dataRetentionDays": "number",
            "exportFormat": "csv|pdf|json",
            "theme": "light|dark"
          },
          "managedBy": "StorageManager"
        },
        "theme": {
          "description": "Current theme setting",
          "values": ["light", "dark"],
          "managedBy": "SecurityApp"
        },
        "tutorial_completed": {
          "description": "Tutorial completion flag",
          "values": ["true", "false"],
          "managedBy": "TutorialManager"
        }
      }
    }
  },
  "dataFlowPatterns": {
    "personnelLifecycle": {
      "description": "Personnel data from creation to removal",
      "steps": [
        {
          "step": 1,
          "action": "User fills personnel form",
          "component": "SecurityApp.showAddPersonnelModal",
          "dataState": "Form data in memory"
        },
        {
          "step": 2,
          "action": "Form submission",
          "component": "SecurityApp.handleAddPersonnelSubmit",
          "dataState": "Validated form data"
        },
        {
          "step": 3,
          "action": "Add to storage",
          "component": "StorageManager.addPersonnel",
          "dataState": "Personnel object with generated ID"
        },
        {
          "step": 4,
          "action": "Persist to localStorage",
          "component": "StorageManager.saveToStorage",
          "dataState": "Data written to localStorage"
        },
        {
          "step": 5,
          "action": "Log activity",
          "component": "StorageManager.logActivity",
          "dataState": "Activity entry created"
        },
        {
          "step": 6,
          "action": "Update UI",
          "component": "SecurityApp.loadPersonnelList",
          "dataState": "UI reflects new personnel"
        }
      ]
    },
    "checkInOutProcess": {
      "description": "Personnel check-in and check-out flow",
      "checkIn": [
        {
          "step": 1,
          "action": "User clicks person card",
          "component": "SecurityApp.handlePersonCardClick",
          "dataState": "Person ID identified"
        },
        {
          "step": 2,
          "action": "Toggle status",
          "component": "SecurityApp.togglePersonStatus",
          "dataState": "Status change requested"
        },
        {
          "step": 3,
          "action": "Update person record",
          "component": "StorageManager.checkIn",
          "dataState": "Person status = checked-in, timestamp set"
        },
        {
          "step": 4,
          "action": "Log activity",
          "component": "StorageManager.logActivity",
          "dataState": "Check-in activity logged"
        },
        {
          "step": 5,
          "action": "Update dashboard",
          "component": "SecurityApp.updateDashboard",
          "dataState": "Occupancy count increased"
        }
      ],
      "checkOut": [
        {
          "step": 1,
          "action": "User clicks checked-in person",
          "component": "SecurityApp.handlePersonCardClick",
          "dataState": "Checked-in person identified"
        },
        {
          "step": 2,
          "action": "Calculate duration",
          "component": "StorageManager.checkOut",
          "dataState": "Visit duration calculated"
        },
        {
          "step": 3,
          "action": "Update person record",
          "component": "StorageManager.checkOut",
          "dataState": "Person status = checked-out, duration recorded"
        },
        {
          "step": 4,
          "action": "Log activity with duration",
          "component": "StorageManager.logActivity",
          "dataState": "Check-out activity with duration logged"
        },
        {
          "step": 5,
          "action": "Update dashboard",
          "component": "SecurityApp.updateDashboard",
          "dataState": "Occupancy count decreased"
        }
      ]
    },
    "dashboardUpdates": {
      "description": "Real-time dashboard data flow",
      "flow": [
        {
          "trigger": "Page navigation to dashboard",
          "component": "SecurityApp.updatePageContent",
          "action": "Calls updateDashboard"
        },
        {
          "trigger": "Data retrieval",
          "component": "StorageManager.getCurrentOccupancy",
          "action": "Calculate current occupancy"
        },
        {
          "trigger": "Statistics calculation",
          "component": "StorageManager.getTodaysStats",
          "action": "Generate today's metrics"
        },
        {
          "trigger": "UI update",
          "component": "SecurityApp.updateCurrentOccupantsList",
          "action": "Refresh occupants display"
        },
        {
          "trigger": "Chart updates",
          "component": "DashboardManager.updateRealTimeData",
          "action": "Refresh charts with new data"
        }
      ]
    },
    "shiftManagement": {
      "description": "Shift lifecycle data flow",
      "startShift": [
        {
          "step": 1,
          "action": "Show start shift modal",
          "component": "SecurityApp.showStartShiftModal",
          "dataState": "Modal form displayed"
        },
        {
          "step": 2,
          "action": "Form submission",
          "component": "SecurityApp.handleStartShift",
          "dataState": "Shift data collected"
        },
        {
          "step": 3,
          "action": "Create shift record",
          "component": "ShiftManager.startShift",
          "dataState": "Shift object created with unique ID"
        },
        {
          "step": 4,
          "action": "Save shift data",
          "component": "ShiftManager.saveShiftData",
          "dataState": "Shift persisted to localStorage"
        },
        {
          "step": 5,
          "action": "Update UI",
          "component": "SecurityApp.updateShiftsPage",
          "dataState": "Current shift displayed"
        }
      ],
      "createHandover": [
        {
          "step": 1,
          "action": "Get current shift",
          "component": "ShiftManager.getCurrentShift",
          "dataState": "Active shift data retrieved"
        },
        {
          "step": 2,
          "action": "Create handover form",
          "component": "SecurityApp.showHandoverModal",
          "dataState": "Handover form with current officers"
        },
        {
          "step": 3,
          "action": "Submit handover",
          "component": "SecurityApp.handleCreateHandover",
          "dataState": "Handover data collected"
        },
        {
          "step": 4,
          "action": "Create handover record",
          "component": "ShiftManager.createHandover",
          "dataState": "Handover object with unique ID"
        },
        {
          "step": 5,
          "action": "Update pending handovers",
          "component": "SecurityApp.updatePendingHandovers",
          "dataState": "Handover displayed in UI"
        }
      ]
    },
    "emergencyProcedures": {
      "description": "Emergency activation and evacuation flow",
      "flow": [
        {
          "step": 1,
          "action": "Emergency button clicked",
          "component": "SecurityApp (emergency-btn event)",
          "dataState": "Emergency mode requested"
        },
        {
          "step": 2,
          "action": "Navigate to emergency page",
          "component": "SecurityApp.navigateTo('emergency')",
          "dataState": "Emergency page displayed"
        },
        {
          "step": 3,
          "action": "Activate emergency mode",
          "component": "EmergencyManager.activateEmergencyMode",
          "dataState": "Emergency status active"
        },
        {
          "step": 4,
          "action": "Generate evacuation list",
          "component": "EmergencyManager.generateEvacuationList",
          "dataState": "Current occupants listed for evacuation"
        },
        {
          "step": 5,
          "action": "Emergency checkout all",
          "component": "EmergencyManager.performEmergencyCheckout",
          "dataState": "All personnel checked out with emergency reason"
        },
        {
          "step": 6,
          "action": "Log emergency activity",
          "component": "StorageManager.logActivity",
          "dataState": "Emergency activation logged"
        }
      ]
    },
    "reportGeneration": {
      "description": "Report data collection and generation",
      "flow": [
        {
          "step": 1,
          "action": "User requests report",
          "component": "SecurityApp.handleAdvancedReport",
          "dataState": "Report type identified"
        },
        {
          "step": 2,
          "action": "Collect source data",
          "component": "ReportsManager.getFilteredActivities",
          "dataState": "Activity data filtered by date range"
        },
        {
          "step": 3,
          "action": "Generate analysis",
          "component": "ReportsManager.generateOccupancyReport",
          "dataState": "Statistical analysis completed"
        },
        {
          "step": 4,
          "action": "Create report object",
          "component": "ReportsManager",
          "dataState": "Structured report with summary and details"
        },
        {
          "step": 5,
          "action": "Display report",
          "component": "SecurityApp.showReportModal",
          "dataState": "Report rendered in modal"
        },
        {
          "step": 6,
          "action": "Export if requested",
          "component": "ExportManager.exportPDF",
          "dataState": "Report exported to file"
        }
      ]
    }
  },
  "dataValidation": {
    "personnelData": {
      "required": ["name", "role"],
      "validation": {
        "name": "Non-empty string",
        "role": "One of: employee, contractor, visitor, vip",
        "email": "Valid email format if provided",
        "phone": "Valid phone format if provided"
      }
    },
    "activityData": {
      "required": ["timestamp", "action", "personId"],
      "validation": {
        "timestamp": "Valid ISO timestamp",
        "action": "Valid action type from enum",
        "personId": "Existing personnel ID"
      }
    },
    "shiftData": {
      "required": ["officer1Name", "shiftType", "startTime"],
      "validation": {
        "officer1Name": "Non-empty string",
        "officer2Name": "Non-empty string if provided",
        "shiftType": "One of: day, night, weekend",
        "startTime": "Valid timestamp",
        "endTime": "Valid timestamp, after startTime"
      }
    }
  },
  "dataRetention": {
    "policy": "90 days default retention",
    "cleanup": {
      "frequency": "On application initialization",
      "method": "StorageManager.cleanupOldData",
      "criteria": "Activities older than dataRetentionDays setting"
    },
    "preservation": {
      "personnel": "Retained indefinitely",
      "currentShifts": "Retained indefinitely", 
      "recentActivities": "Retained per policy",
      "settings": "Retained indefinitely"
    }
  },
  "synchronization": {
    "localSync": {
      "frequency": "Every 30 seconds",
      "component": "Various sync managers",
      "dataTypes": ["personnel", "activities", "shifts"],
      "conflictResolution": "Last-write-wins with timestamp comparison"
    },
    "offlineSupport": {
      "strategy": "Queue operations when offline",
      "syncOnReconnect": "StorageManager.syncOfflineData",
      "storage": "localStorage maintains state during offline periods"
    }
  },
  "performanceOptimizations": {
    "dataAccess": {
      "caching": "In-memory data cache in StorageManager",
      "batchUpdates": "Throttled auto-save operations",
      "indexing": "Personnel indexed by ID for quick lookup"
    },
    "uiUpdates": {
      "debouncing": "Search input debounced",
      "pagination": "Activity log paginated",
      "lazyLoading": "Charts loaded on demand"
    }
  }
}